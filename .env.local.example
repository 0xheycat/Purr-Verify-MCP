# Local/public runner overrides for self-hosted Purr Verify MCP.
# Copy selected values into .env. Never put secrets in this file.

# Shared package caches reduce transient install failures across fresh workspaces.
# The runner still retries transient Bun extraction/network failures once with a fresh cache.
PURR_VERIFY_BUN_CACHE_DIR=/tmp/purr-verify-bun-cache
PURR_VERIFY_NPM_CACHE_DIR=/tmp/purr-verify-npm-cache
PURR_VERIFY_XDG_CACHE_HOME=/tmp/purr-verify-xdg-cache

# Heavy public repos need more than the tiny defaults.
COMMAND_TIMEOUT_MS=1800000
JOB_TIMEOUT_MS=7200000

# Optional fallback toolchains for repos without exact declarations.
TOOLCHAIN_DEFAULT_NODE=26.3.0
TOOLCHAIN_DEFAULT_BUN=1.3.14

# Optional Surfpool/fork smoke support. Install cargo/rustc/surfpool on the host.
# /api/health should report runnerTools.surfpool.available=true before fork jobs rely on it.
# cargo --version
# rustc --version
# surfpool --version
