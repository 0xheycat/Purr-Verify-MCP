# Copy this file to .env and fill in real values. Never commit .env.
#
# Purr Verify MCP — configuration reference:
#   https://github.com/0xheycat/Purr-Verify-MCP#environment-variables

# ----------------------------------------------------------------------------
# Authentication mode
# ----------------------------------------------------------------------------
# server_token      — Bearer token must equal VERIFY_TOKEN, or a valid embedded
#                     OAuth token issued by this app. Cloning private repos uses
#                     GITHUB_TOKEN below. Recommended for ChatGPT OAuth.
# github_passthrough— Bearer token is a GitHub PAT. The server validates it via
#                     GET https://api.github.com/user and reuses the same PAT.
AUTH_MODE=server_token
# AUTH_MODE=github_passthrough

# ----------------------------------------------------------------------------
# OAuth protected-resource + embedded authorization server for ChatGPT Apps
# ----------------------------------------------------------------------------
# One-domain setup is supported: verify.pursr.xyz serves both /mcp and /oauth/*.
PUBLIC_BASE_URL=https://verify.pursr.xyz
OAUTH_RESOURCE_URL=https://verify.pursr.xyz/mcp
OAUTH_AUTHORIZATION_SERVERS=https://verify.pursr.xyz
OAUTH_SCOPES_SUPPORTED=verify:run verify:read repo read:user user:email
OAUTH_RESOURCE_NAME=Purr Verify MCP
OAUTH_REALM=purr-verify-mcp

# Embedded OAuth authorization server. In ChatGPT use User-Defined OAuth Client.
OAUTH_ISSUER=https://verify.pursr.xyz
OAUTH_CLIENT_ID=chatgpt-purr-verify
OAUTH_ALLOWED_REDIRECT_URIS=
OAUTH_OWNER_CODE=
OAUTH_JWT_SECRET=
OAUTH_TOKEN_TTL_SECONDS=3600
OAUTH_SUBJECT=0xheycat

# ----------------------------------------------------------------------------
# server_token mode
# ----------------------------------------------------------------------------
# Bearer token clients send as "Authorization: Bearer <VERIFY_TOKEN>".
# Required when AUTH_MODE=server_token. Also used as fallback JWT secret if
# OAUTH_JWT_SECRET is empty, but production should set OAUTH_JWT_SECRET separately.
VERIFY_TOKEN=change-me-to-a-long-random-string

# ----------------------------------------------------------------------------
# Private repo cloning
# ----------------------------------------------------------------------------
# Optional GitHub token used to clone private repos in server_token/oauth mode.
# In github_passthrough mode the per-request bearer is used instead.
GITHUB_TOKEN=

# ----------------------------------------------------------------------------
# Repository allowlist
# ----------------------------------------------------------------------------
ALLOWED_REPOS=*
# ALLOWED_REPOS=0xheycat/Purr-github-MCP,0xheycat/Purrliquid
# ALLOW_ALL_REPOS=false

# ----------------------------------------------------------------------------
# Execution limits
# ----------------------------------------------------------------------------
WORKDIR_BASE=.verify-workspaces
MAX_LOG_BYTES=500000
COMMAND_TIMEOUT_MS=1800000
JOB_TIMEOUT_MS=7200000
MAX_CONCURRENT_JOBS=1
CLEANUP_AFTER_MS=3600000

# ----------------------------------------------------------------------------
# Global toolchain fallback
# ----------------------------------------------------------------------------
TOOLCHAIN_DEFAULT_NODE=
TOOLCHAIN_DEFAULT_BUN=
# TOOLCHAIN_CACHE_DIR=/tmp/purr-verify-toolchains
