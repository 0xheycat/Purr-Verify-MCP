# Copy this file to .env and fill in real values. Never commit .env.
#
# Purr Verify MCP — configuration reference:
#   https://github.com/0xheycat/Purr-Verify-MCP#environment-variables

# ----------------------------------------------------------------------------
# Authentication mode
# ----------------------------------------------------------------------------
# server_token      — Bearer token must equal VERIFY_TOKEN (constant-time
#                     compare). Cloning private repos uses GITHUB_TOKEN below.
#                     Good for stable / single-tenant deployments. (default)
# github_passthrough— Bearer token is a GitHub PAT. The server validates it by
#                     calling GET https://api.github.com/user and reuses the
#                     SAME PAT to clone private repos. Handy for MCP clients
#                     that can paste a PAT directly as the bearer.
AUTH_MODE=server_token
# AUTH_MODE=github_passthrough

# ----------------------------------------------------------------------------
# server_token mode
# ----------------------------------------------------------------------------
# Bearer token clients send as "Authorization: Bearer <VERIFY_TOKEN>".
# Required when AUTH_MODE=server_token. Optional otherwise.
VERIFY_TOKEN=change-me-to-a-long-random-string

# ----------------------------------------------------------------------------
# Private repo cloning
# ----------------------------------------------------------------------------
# Optional GitHub token used to clone private repos in server_token mode.
# In github_passthrough mode the per-request bearer is used instead, so this
# is not needed. Never logged; redacted from all captured output.
GITHUB_TOKEN=

# ----------------------------------------------------------------------------
# Repository allowlist
# ----------------------------------------------------------------------------
# Options:
#   - Comma-separated owner/repo list, e.g. 0xheycat/Purr-github-MCP,0xheycat/Purrliquid
#   - "*" / empty / unset  -> unrestricted mode (any owner/repo matching the
#                             safe regex /^[A-Za-z0-9_.-]+\/[A-Za-z0-9_.-]+$/)
#   - ALLOW_ALL_REPOS=true  -> force unrestricted mode regardless of the list
# Unrestricted mode still validates the slug format and only clones from
# github.com. Arbitrary git URLs are never accepted.
ALLOWED_REPOS=*
# ALLOWED_REPOS=0xheycat/Purr-github-MCP,0xheycat/Purrliquid
# ALLOW_ALL_REPOS=false

# ----------------------------------------------------------------------------
# Execution limits
# ----------------------------------------------------------------------------
# Base directory for fresh per-job workspaces (created on demand)
WORKDIR_BASE=.verify-workspaces

# Max captured stdout/stderr per command (bytes)
MAX_LOG_BYTES=500000

# Per-command timeout (ms) — recommended 30 minutes for public runners / heavy Next builds
COMMAND_TIMEOUT_MS=1800000

# Per-job overall timeout (ms) — recommended 2 hours for install + build + full test verification
JOB_TIMEOUT_MS=7200000

# Max concurrent verification jobs (extras queue)
MAX_CONCURRENT_JOBS=1

# Auto-cleanup delay for finished job workspaces (ms) — default 1 hour
CLEANUP_AFTER_MS=3600000

# ----------------------------------------------------------------------------
# Global toolchain fallback
# ----------------------------------------------------------------------------
# If a cloned repo does not declare exact Node/Bun versions, the runner can use
# these safe global defaults instead of the host process versions. Repos should
# still declare their own versions for maximum reproducibility; jobs will emit
# recommendations when declarations are missing.
TOOLCHAIN_DEFAULT_NODE=
TOOLCHAIN_DEFAULT_BUN=

# Where downloaded Node/Bun toolchains are cached between jobs.
# TOOLCHAIN_CACHE_DIR=/tmp/purr-verify-toolchains
